<Window x:Class="XTouchVMBridge.App.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XV — Log"
        Height="500" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                    <Canvas Width="16" Height="16">
                        <Path Stroke="#569CD6" StrokeThickness="1.3"
                              Data="M3,2 L10,2 L13,5 L13,14 L3,14 Z M10,2 L10,5 L13,5 M5,7 L11,7 M5,10 L11,10"/>
                    </Canvas>
                </Viewbox>
                <TextBlock Text="Log Monitor" Foreground="#569CD6" FontFamily="Consolas"
                           FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Log Level:" Foreground="#CCC" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="LogLevelCombo" Width="120"
                      SelectionChanged="OnLogLevelChanged">
                <ComboBoxItem Content="DEBUG"/>
                <ComboBoxItem Content="INFO" IsSelected="True"/>
                <ComboBoxItem Content="WARNING"/>
                <ComboBoxItem Content="ERROR"/>
            </ComboBox>

            <CheckBox x:Name="AutoScrollCheck" Content="Auto-Scroll"
                      IsChecked="True" Foreground="#CCC"
                      VerticalAlignment="Center" Margin="16,0,0,0"/>

            <Button Content="Clear" Margin="16,0,0,0" Padding="12,4"
                    Click="OnClearClick"/>

            <Button Content="Im Explorer öffnen" Margin="16,0,0,0" Padding="12,4"
                    Click="OnOpenInExplorerClick"/>
        </StackPanel>

        <!-- Log Output -->
        <TextBox Grid.Row="1"
                 x:Name="LogTextBox"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="#1E1E1E"
                 Foreground="#DCDCDC"
                 BorderThickness="1"
                 BorderBrush="#333"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"/>
    </Grid>
</Window>
