<Window x:Class="XTouchVMBridge.App.Views.ChannelViewEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Channel Views bearbeiten" Width="720" Height="520"
        Background="#111" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip" MinWidth="600" MinHeight="400">

    <Window.Resources>
        <!-- SystemColors für dunkle Dropdowns -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#DDD"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A5A8A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFF"/>

        <!-- Dark ComboBox mit vollständigem Template -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#2A2A2A"
                        BorderBrush="#555" BorderThickness="1" CornerRadius="2"/>
                <Border Grid.Column="0" Background="Transparent" Margin="1"/>
                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="#AAA"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#888"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#0AF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource DarkComboBoxToggleButton}"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="6,2,24,2"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#DDD"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Background="Transparent" Foreground="#DDD"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="6,2,24,2" Focusable="True"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#2A2A2A" BorderBrush="#555"
                                            BorderThickness="1" CornerRadius="2"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3A5A8A"/>
                    <Setter Property="Foreground" Value="#FFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A5A8A"/>
                    <Setter Property="Foreground" Value="#FFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A5A8A"/>
                    <Setter Property="Foreground" Value="#FFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DarkLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Links: View-Liste -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock DockPanel.Dock="Top" Text="Views" Foreground="#0AF" FontWeight="Bold"
                       FontSize="14" Margin="0,0,0,6"/>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="+" Style="{StaticResource DarkButton}" Width="30"
                        Click="OnAddView" ToolTip="Neue View hinzufügen"/>
                <Button Content="−" Style="{StaticResource DarkButton}" Width="30"
                        Click="OnRemoveView" ToolTip="Ausgewählte View entfernen"/>
            </StackPanel>

            <ListBox x:Name="ViewList" Background="#1A1A1A" BorderBrush="#333"
                     Foreground="#DDD" SelectionChanged="OnViewSelected"/>
        </DockPanel>

        <!-- Rechts: View-Details -->
        <Border Grid.Column="1" Background="#1A1A1A" BorderBrush="#333"
                BorderThickness="1" CornerRadius="4" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailPanel">
                    <TextBlock Text="View-Einstellungen" Foreground="#0AF"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <!-- Name -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Name:" Style="{StaticResource DarkLabel}" Width="50"/>
                        <TextBox x:Name="ViewNameBox" Width="100" MaxLength="7"
                                 Background="#222" Foreground="#DDD" BorderBrush="#555"
                                 FontFamily="Consolas" FontSize="12" Padding="4,2"
                                 TextChanged="OnViewNameChanged"/>
                    </StackPanel>

                    <!-- Kanal-Zuweisungen (8 Strips) -->
                    <TextBlock Text="Kanal-Zuordnung (8 Strips)" Foreground="#888"
                               FontSize="11" Margin="0,8,0,6"/>

                    <Grid x:Name="ChannelGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Rows werden dynamisch erzeugt -->
                    </Grid>

                    <!-- Main Fader -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <TextBlock Text="Main Fader:" Style="{StaticResource DarkLabel}" Width="80"/>
                        <ComboBox x:Name="MainFaderCombo" Width="180"
                                  SelectionChanged="OnMainFaderChanged"/>
                    </StackPanel>

                    <TextBlock Text="(optional — VM-Kanal für den Main Fader)"
                               Foreground="#666" FontSize="10" Margin="84,0,0,0"/>

                    <!-- Speichern -->
                    <Button Content="Speichern" Style="{StaticResource DarkButton}"
                            HorizontalAlignment="Left" Margin="0,16,0,0"
                            Click="OnSave"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
