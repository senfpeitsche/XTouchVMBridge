<Window x:Class="XTouchVMBridge.App.Views.MqttConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MQTT Server"
        Width="520" Height="620"
        Background="#111" WindowStartupLocation="CenterOwner"
        MinWidth="520" MinHeight="520">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Aktiviert:"/>
                <CheckBox Grid.Row="0" Grid.Column="1" x:Name="EnabledBox" Content="MQTT aktivieren"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Host:"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="HostBox"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Port:"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="PortBox" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="TLS:"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                    <CheckBox x:Name="UseTlsBox" Content="TLS verwenden"/>
                    <CheckBox x:Name="AllowUntrustedBox" Content="Unsichere Zertifikate zulassen" Margin="12,2,0,2"/>
                </StackPanel>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Client-ID:"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="ClientIdBox"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Benutzer:"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="UsernameBox"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Passwort:"/>
                <PasswordBox Grid.Row="6" Grid.Column="1" x:Name="PasswordBox"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="KeepAlive (s):"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="KeepAliveBox" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="Session:"/>
                <CheckBox Grid.Row="8" Grid.Column="1" x:Name="CleanSessionBox" Content="Clean Session"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="Publish Topic:"/>
                <TextBox Grid.Row="9" Grid.Column="1" x:Name="PublishTopicBox"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Publish QoS:"/>
                <ComboBox Grid.Row="10" Grid.Column="1" x:Name="PublishQosBox" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Publish Retain:"/>
                <CheckBox Grid.Row="11" Grid.Column="1" x:Name="PublishRetainBox" Content="Retain-Flag setzen"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Text="Subscribe Topics:"/>
                <TextBox Grid.Row="12" Grid.Column="1" x:Name="SubscribeTopicsBox"
                         AcceptsReturn="True" Height="120" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" ToolTip="Ein Topic pro Zeile"/>

                <TextBlock Grid.Row="13" Grid.Column="0" Text="Subscribe QoS:"/>
                <ComboBox Grid.Row="13" Grid.Column="1" x:Name="SubscribeQosBox" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="14" Grid.Column="0" Text="Status:"/>
                <TextBlock Grid.Row="14" Grid.Column="1" x:Name="StatusText" Foreground="#888" Text=""/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Testen" Click="OnTestConnection"/>
            <Button Content="Speichern" Background="#1E3A1E" Foreground="#6CBF6C" Click="OnSave"/>
            <Button Content="Abbrechen" Background="#3C0F0F" Foreground="#FF6666" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
