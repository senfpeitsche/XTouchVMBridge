<Window x:Class="AudioManager.App.Views.XTouchPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="X-Touch — Live Panel" Width="1440" Height="820"
        Background="#111" WindowStartupLocation="CenterScreen" MinWidth="1200" MinHeight="700">

    <Window.Resources>
        <!-- Globale Stile -->
        <Style x:Key="ChannelBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <!-- Button-Stil für Rec/Solo/Mute/Select -->
        <Style x:Key="HwButton" TargetType="Button">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Master Section kleine Buttons -->
        <Style x:Key="MasterButton" TargetType="Button">
            <Setter Property="Height" Value="22"/>
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="3,1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transport-Button (größer) -->
        <Style x:Key="TransportButton" TargetType="Button" BasedOn="{StaticResource MasterButton}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Encoder-Ring -->
        <Style x:Key="EncoderButton" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="#222" Stroke="#555" StrokeThickness="2"/>
                            <Ellipse Fill="#333" Width="20" Height="20"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fader-Slider -->
        <Style x:Key="FaderSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Height" Value="160"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Minimum" Value="-8192"/>
            <Setter Property="Maximum" Value="8188"/>
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Section Header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hauptbereich: 8 Kanäle + Master Section -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 8+1 Kanäle (8 Strips + Main Fader) -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <UniformGrid Grid.Column="0" Columns="8" x:Name="ChannelGrid"/>
                <!-- Main Fader Strip -->
                <Border Grid.Column="1" x:Name="MainFaderBorder"
                        BorderBrush="#444" BorderThickness="1" CornerRadius="4"
                        Background="#1A1A1A" Margin="3" Padding="6" Width="70">
                    <StackPanel x:Name="MainFaderPanel" HorizontalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Master Section (rechts) -->
            <Border Grid.Column="1" BorderBrush="#444" BorderThickness="1" CornerRadius="6"
                    Background="#181818" Margin="4,0,0,0" Padding="8" Width="340">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="MasterSectionPanel">

                        <!-- Titel -->
                        <TextBlock Text="UNIVERSAL CONTROL SURFACE" Foreground="#569CD6"
                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>

                        <!-- ENCODER ASSIGN -->
                        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                                Background="#1A1A1A" Padding="4" Margin="0,2">
                            <StackPanel>
                                <TextBlock Text="ENCODER ASSIGN" Style="{StaticResource SectionHeader}"/>
                                <WrapPanel HorizontalAlignment="Center" x:Name="EncoderAssignPanel"/>
                            </StackPanel>
                        </Border>

                        <!-- DISPLAY + SEGMENT -->
                        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                                Background="#1A1A1A" Padding="4" Margin="0,2">
                            <StackPanel>
                                <TextBlock Text="DISPLAY / ASSIGNMENT" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Name/Value + SMPTE/Beats -->
                                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                        <WrapPanel x:Name="DisplayModePanel"/>
                                    </StackPanel>
                                    <!-- 7-Segment Display -->
                                    <Border Grid.Column="1" Background="#0A0A0A" CornerRadius="3" Padding="6,4">
                                        <TextBlock x:Name="SegmentDisplay" Text="00 00 00 00 00"
                                                   Foreground="#FF4444" FontFamily="Consolas"
                                                   FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- GLOBAL VIEW -->
                        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                                Background="#1A1A1A" Padding="4" Margin="0,2">
                            <StackPanel>
                                <TextBlock Text="GLOBAL VIEW" Style="{StaticResource SectionHeader}"/>
                                <WrapPanel HorizontalAlignment="Center" x:Name="GlobalViewPanel"/>
                            </StackPanel>
                        </Border>

                        <!-- FUNCTION -->
                        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                                Background="#1A1A1A" Padding="4" Margin="0,2">
                            <StackPanel>
                                <TextBlock Text="FUNCTION" Style="{StaticResource SectionHeader}"/>
                                <WrapPanel HorizontalAlignment="Center" x:Name="FunctionPanel"/>
                            </StackPanel>
                        </Border>

                        <!-- MODIFY / AUTOMATION / UTILITY -->
                        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                                Background="#1A1A1A" Padding="4" Margin="0,2">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="MODIFY" Style="{StaticResource SectionHeader}"/>
                                        <StackPanel x:Name="ModifyPanel"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="AUTOMATION" Style="{StaticResource SectionHeader}"/>
                                        <StackPanel x:Name="AutomationPanel"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="UTILITY" Style="{StaticResource SectionHeader}"/>
                                        <StackPanel x:Name="UtilityPanel"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- TRANSPORT -->
                        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                                Background="#1A1A1A" Padding="4" Margin="0,2">
                            <StackPanel>
                                <TextBlock Text="TRANSPORT" Style="{StaticResource SectionHeader}"/>
                                <WrapPanel HorizontalAlignment="Center" x:Name="TransportTopPanel" Margin="0,0,0,4"/>
                                <StackPanel HorizontalAlignment="Center" x:Name="TransportButtonPanel" Orientation="Horizontal"/>
                            </StackPanel>
                        </Border>

                        <!-- FADER BANK / CHANNEL + JOG WHEEL -->
                        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="3"
                                Background="#1A1A1A" Padding="4" Margin="0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Fader Bank / Channel Buttons -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="FADER BANK" Style="{StaticResource SectionHeader}"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" x:Name="FaderBankPanel"/>
                                    <TextBlock Text="CHANNEL" Style="{StaticResource SectionHeader}" Margin="0,4,0,4"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" x:Name="ChannelNavPanel"/>
                                </StackPanel>

                                <!-- Jog Wheel -->
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="JOG / SCRUB" Style="{StaticResource SectionHeader}"/>
                                    <Button x:Name="JogWheelButton" Width="100" Height="100" Cursor="Hand"
                                            ToolTip="Jog Wheel — CC 88">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Ellipse Fill="#1E1E1E" Stroke="#555" StrokeThickness="3"/>
                                                    <Ellipse Fill="#222" Width="60" Height="60" Stroke="#444" StrokeThickness="1"/>
                                                    <Ellipse Fill="#333" Width="30" Height="30"/>
                                                    <TextBlock Text="JOG" Foreground="#888" FontFamily="Consolas"
                                                               FontSize="9" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="JogWheelLabel" Text="CC 88" Foreground="#666"
                                               FontFamily="Consolas" FontSize="8"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Detail-Panel unten -->
        <Border Grid.Row="1" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,1,0,0"
                Margin="0,6,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="DetailHeader"
                           Text="Klicke auf ein Control um Details zu sehen"
                           Foreground="#569CD6" FontFamily="Consolas" FontSize="13"
                           FontWeight="Bold" VerticalAlignment="Top" Margin="0,0,16,0"/>

                <TextBlock Grid.Column="1" x:Name="DetailText"
                           Text="" Foreground="#D4D4D4" FontFamily="Consolas" FontSize="12"
                           TextWrapping="Wrap" VerticalAlignment="Top"/>
            </Grid>
        </Border>
    </Grid>
</Window>
